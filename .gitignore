# ── Dependencies ──────────────────────────────────────────────────────
node_modules/

# ── Environment variables ─────────────────────────────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local
RENDER_ENV_SECRETS.md

# ── Build output (regenerated by Render on deploy) ────────────────────
frontend/dist/
frontend/build/

# ── Test coverage (generated by npm test) ─────────────────────────────
backend/coverage/

# ── Logs ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code ───────────────────────────────────────────────────────
.claude/
CLAUDE.md

# ── Uploaded user files (avatar users — lưu ngoài git) ───────────────
frontend/public/avatars/*
!frontend/public/avatars/.gitkeep
backend/public/uploads/avatars/*
!backend/public/uploads/avatars/.gitkeep

# ── Database migration/debug scripts (đã apply hoặc chỉ dùng cục bộ) ─
database/fix_*.sql
database/migrate_*.sql
database/verify_*.sql
database/run_*.sh

# ── Temp / misc ───────────────────────────────────────────────────────
/tmp/
*.bak
*.tmp
