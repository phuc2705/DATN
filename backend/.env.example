# ════════════════════════════════════════════════════════════════
#  CleanConnect — Backend Environment Variables
#  Sao chép file này thành .env và điền giá trị thực
# ════════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production

# ─── Database (MySQL) ────────────────────────────────────────────
DB_HOST=localhost             # production: hostname cloud MySQL (Railway/PlanetScale...)
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=housekeeping_service
DB_SSL=false                  # production: true (bắt buộc với cloud MySQL)

# ─── JWT ─────────────────────────────────────────────────────────
# Dùng chuỗi ngẫu nhiên mạnh ≥ 32 ký tự khi deploy production
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS / URL ──────────────────────────────────────────────────
# development: http://localhost:3000 hoặc http://localhost:5173
# production:  https://datn-fafj.onrender.com (hoặc domain riêng)
CLIENT_URL=http://localhost:3000

# ─── Gmail OAuth2 (Gửi email OTP & thông báo) ───────────────────
# Lấy tại: console.cloud.google.com → OAuth 2.0 Client IDs
# Dùng OAuth Playground (https://developers.google.com/oauthplayground)
# để lấy GMAIL_REFRESH_TOKEN với scope: https://mail.google.com/
EMAIL_USER=your_gmail@gmail.com
GMAIL_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your_client_secret
GMAIL_REFRESH_TOKEN=1//your_refresh_token

# ─── Firebase Admin SDK (Xác thực Google Login) ──────────────────
# Lấy tại: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── VNPay (Thanh toán) ──────────────────────────────────────────
# Sandbox: https://sandbox.vnpayment.vn/apis/vnpay-demo/
# Production: https://vnpayment.vn/
VNP_TMN_CODE=YOUR_TMN_CODE
VNP_HASH_SECRET=YOUR_HASH_SECRET
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# development:  http://localhost:5000/api/payments/vnpay-return
# production:   https://datn-fafj.onrender.com/api/payments/vnpay-return
VNP_RETURN_URL=http://localhost:5000/api/payments/vnpay-return

# ─── Ngân hàng Test VNPay ────────────────────────────────────────
BANK_ID=NCB
BANK_ACCOUNT=9704198526191432198
BANK_HOLDER=NGUYEN VAN A
BANK_NAME=Ngan hang Quoc Dan (NCB)

# ─── Test / Dev ──────────────────────────────────────────────────
# Email được phép đăng ký lại nhiều lần (dùng để test)
TEST_EMAILS=your_test_email@gmail.com
# Tự xóa tài khoản test sau N phút kể từ khi verify OTP (mặc định 30)
TEST_CLEANUP_MINUTES=30

# ─── Tùy chọn khác ───────────────────────────────────────────────
# FORCE_REINIT=true   # Bắt buộc tạo lại toàn bộ schema (XÓA DỮ LIỆU — chỉ dùng khi cần reset DB)
